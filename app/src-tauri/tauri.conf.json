{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Coding Agent",
  "version": "0.1.0",
  "identifier": "com.local.agent",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local AI Coding Agent",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ]
  }
}
